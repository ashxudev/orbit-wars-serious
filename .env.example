# Local Daytona credentials and execution guard.
# Copy to .env and fill local values. Never commit .env.

# Required to permit real Daytona execution through this repo's guarded CLI.
OW_EVAL_ALLOW_REAL_DAYTONA=0

# Required by the Daytona Python SDK.
DAYTONA_API_KEY=
DAYTONA_TARGET=us

# Optional SDK API URL override. Leave blank for Daytona's default API URL.
# DAYTONA_API_URL=

# Default real-run source path: the sandbox clones this GitHub repository and
# checks out the exact pushed commit. DAYTONA_GIT_REF=auto resolves local HEAD.
DAYTONA_SOURCE_MODE=github
DAYTONA_GITHUB_REPO=https://github.com/ashxudev/orbit-wars-serious.git
DAYTONA_GIT_REF=auto
DAYTONA_GITHUB_TOKEN_ENV_VAR=DAYTONA_GITHUB_TOKEN
DAYTONA_GITHUB_TOKEN=
DAYTONA_GIT_REMOTE=origin
DAYTONA_GIT_BRANCH=main

# Snapshot/image fallback only. In GitHub mode, snapshots are cache/base images,
# not source of truth. Set DAYTONA_SOURCE_MODE=snapshot or local to use this
# older source path intentionally.
DAYTONA_SNAPSHOT_ID=auto
# DAYTONA_IMAGE=
DAYTONA_WORKING_DIR=/workspace/orbit-wars-serious
DAYTONA_SANDBOX_NAME_PREFIX=ow-historical-gauntlet
