# Local Daytona credentials and execution guard.
# Copy to .env and fill local values. Never commit .env.

# Required to permit real Daytona execution through this repo's guarded CLI.
OW_EVAL_ALLOW_REAL_DAYTONA=0

# Required by the Daytona Python SDK.
DAYTONA_API_KEY=
DAYTONA_TARGET=us

# Optional SDK API URL override. Leave blank for Daytona's default API URL.
# DAYTONA_API_URL=

# Recommended path for repeated full-horizon gauntlets: use the default
# current-HEAD snapshot name. The real runner resolves "auto" to
# ow-serious-runtime-<current-commit-12> and verifies the snapshot's
# .ow-runtime-git-commit marker before running. Recreate the snapshot after
# committing runner/package behavior changes; no .env edit is needed unless
# using a custom snapshot name.
DAYTONA_SNAPSHOT_ID=auto
# DAYTONA_IMAGE=
DAYTONA_WORKING_DIR=/workspace/orbit-wars-serious
DAYTONA_SANDBOX_NAME_PREFIX=ow-historical-gauntlet

# Optional clone-bootstrap path only. Use this if the remote sandbox must clone
# a private GitHub repo instead of starting from a prepared snapshot/image.
OW_EVAL_REQUIRE_GITHUB_TOKEN=0
GITHUB_TOKEN=
